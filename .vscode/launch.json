{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pico Debug",
            "type": "probe-rs-debug",
            "request": "launch",
            "preLaunchTask": "rust: cargo build",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": false
            },
            "chip": "rp2040",
            "coreConfigs": [
                {
                    "programBinary": "${workspaceFolder}/target/thumbv6m-none-eabi/debug/firmware"
                }
            ]
        }
    ]
}